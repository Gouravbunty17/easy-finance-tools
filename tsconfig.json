{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src", "api", "scripts", "vite.config.js"],
  "exclude": [
    "dist",
    "node_modules",
    ".vercel",
    ".gstack",
    ".codex",
    "qa-output",
    "easy-finance-tools-ai-cost-calculator-v3",
    "ecc"
  ]
}
