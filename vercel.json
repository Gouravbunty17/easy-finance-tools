{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000" }
      ]
    },
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@5.3.24"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.easyfinancetools.com"
        }
      ],
      "destination": "https://easyfinancetools.com/:path*",
      "permanent": true
    },
    {
      "source": "/blog/rrsp-deadline-canada-2026",
      "destination": "/blog/rrsp-deadline-2026",
      "permanent": true
    },
    {
      "source": "/blog/tfsa-contribution-room-canada-2026",
      "destination": "/blog/how-much-tfsa-room-2026",
      "permanent": true
    },
    {
      "source": "/blog/tfsa-vs-rrsp-2026",
      "destination": "/blog/tfsa-vs-rrsp-vs-fhsa-canada",
      "permanent": true
    },
    {
      "source": "/blog/tfsa-vs-rrsp-canada-2026",
      "destination": "/blog/tfsa-vs-rrsp-vs-fhsa-canada",
      "permanent": true
    },
    {
      "source": "/blog/best-canadian-dividend-etfs-2026",
      "destination": "/blog/best-etfs-for-tfsa-canada-2026",
      "permanent": true
    },
    {
      "source": "/calculators",
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/calculators/:path*",
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/shop",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/stocks/:slug*",
      "destination": "/",
      "permanent": true
    }
  ]
}
