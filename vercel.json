{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000" }
      ]
    },
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@5.3.24"
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.easyfinancetools.com"
        }
      ],
      "destination": "https://easyfinancetools.com/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.easyfinancetools.com"
        }
      ],
      "destination": "https://easyfinancetools.com/$1",
      "permanent": true
    },
    {
      "source": "/calculators",
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/calculators/:path*",
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/tfsa-calculator",
      "destination": "/tools/tfsa-calculator",
      "permanent": true
    },
    {
      "source": "/rrsp-calculator",
      "destination": "/tools/rrsp-calculator",
      "permanent": true
    },
    {
      "source": "/fhsa-calculator",
      "destination": "/tools/fhsa-calculator",
      "permanent": true
    },
    {
      "source": "/mortgage-calculator",
      "destination": "/tools/mortgage-calculator",
      "permanent": true
    },
    {
      "source": "/compound-interest-calculator",
      "destination": "/tools/compound-interest-calculator",
      "permanent": true
    },
    {
      "source": "/dividend-calculator",
      "destination": "/tools/dividend-calculator",
      "permanent": true
    },
    {
      "source": "/income-tax-calculator",
      "destination": "/tools/income-tax-calculator",
      "permanent": true
    },
    {
      "source": "/savings-calculator",
      "destination": "/tools/savings-goal",
      "permanent": true
    },
    {
      "source": "/blog/how-to-invest-in-canada",
      "destination": "/blog/how-to-start-investing-canada-2026",
      "permanent": true
    },
    {
      "source": "/disclosure",
      "destination": "/affiliate-disclosure",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/shop",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/stocks/:slug*",
      "destination": "/",
      "permanent": true
    }
  ]
}
